{
	"compilerOptions": {
		"paths": {
			"@/common/*": ["src/common/*"],
			"@/config/*": ["src/config/*"],
			"@/context": ["test/context.ts"],
			"@/controllers/*": ["src/controllers/*"],
			"@/fixtures/*": ["test/fixtures/*"],
			"@/helper": ["test/helper.ts"],
			"@/infrastructure/*": ["src/infrastructure/*"],
			"@/middleware/*": ["src/middleware/*"],
			"@/models/*": ["src/models/*"],
			"@/prismaClient": ["generated/prisma/client.ts"],
			"@/repositories/*": ["src/repositories/*"],
			"@/routes/*": ["src/routes/*"],
			"@/serializers/*": ["src/models/serializers/*"],
			"@/services/*": ["src/services/*"],
			"@/src/*": ["src/*"],
			"@/types/*": ["src/models/types/*"],
			"@/validators/*": ["src/models/validators/*"]
		}
	},
	"exclude": [
		"node_modules",
		".husky",
		"dist",
		"test/**/coverage/**",
		"test/**/reports/**"
	],
	"extends": "../tsconfig.json",
	"include": ["test/**/*.ts", "src/**/*.ts", "generated/**/*.ts"]
}
