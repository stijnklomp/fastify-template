{
	"name": "fastify-template",
	"version": "1.0.0",
	"private": false,
	"description": "",
	"license": "MIT",
	"type": "module",
	"main": "dist/app.js",
	"directories": {
		"test": "test"
	},
	"scripts": {
		"build": "rm -rf dist && bun build src/app.ts --tsconfig=tsconfig.production.json --target=bun --format=esm --outdir=dist --minify --sourcemap=none",
		"dev": "ENV=development LOGS=development bun --watch src/app.ts",
		"doc": "typedoc",
		"integrity": "./scripts/integrity.sh",
		"lint": "eslint --report-unused-disable-directives . --cache",
		"lint:fix": "bun run sort ; eslint --report-unused-disable-directives . --cache --fix",
		"migrate": "bunx prisma migrate deploy",
		"prepare": "husky",
		"prisma:generate": "bunx prisma generate",
		"sort": "./node_modules/stijnklomp-linting-formatting-config/sortJson.sh ./tsconfig.json ./test/tsconfig.json ./.lintstagedrc.json",
		"start": "bun run dist/app.js",
		"test": "bun run test:unit",
		"test:acceptance": "ENV=test LOGS=test bun test test/acceptance",
		"test:coverage": "bun run test:unit:coverage",
		"test:feature": "ENV=test LOGS=test bun test test/feature",
		"test:unit": "ENV=test LOGS=test bun test test/unit",
		"test:unit:ci": "ENV=test LOGS=test bun test --ci test/unit --coverage",
		"test:unit:coverage": "ENV=test LOGS=test bun test --cov test/unit --coverage"
	},
	"dependencies": {
		"@fastify/autoload": "^6.3.1",
		"@fastify/helmet": "^13.0.2",
		"@fastify/sensible": "^6.0.4",
		"@fastify/swagger": "^9.7.0",
		"@fastify/type-provider-typebox": "^6.1.0",
		"@opentelemetry/api": "^1.9.0",
		"@prisma/adapter-pg": "^7.4.2",
		"@prisma/client": "^7.4.2",
		"@sinclair/typebox": "^0.34.47",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"amqplib": "^0.10.9",
		"fastify": "^5.8.1",
		"fastify-plugin": "^5.1.0",
		"fluent-json-schema": "^6.0.0",
		"globals": "^17.4.0",
		"hyperid": "^3.3.0",
		"pg": "^8.20.0",
		"readable-stream": "^4.7.0",
		"redis": "^5.11.0",
		"stijnklomp-linting-formatting-config": "^7.0.4"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@socketsecurity/bun-security-scanner": "^1.1.2",
		"@types/amqplib": "^0.10.8",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.3",
		"bun-mock-prisma": "^1.2.1",
		"eslint": "^10.0.2",
		"eslint-plugin-jest": "^29.15.0",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-markdown": "^5.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-yml": "^3.3.1",
		"husky": "^9.1.7",
		"json-sort-cli": "^4.1.3",
		"lint-staged": "^16.3.2",
		"micromatch": "^4.0.8",
		"prettier": "^3.8.0",
		"prettier-plugin-packagejson": "^3.0.2",
		"prisma": "^7.4.2",
		"typedoc": "^0.28.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"engines": {
		"bun": ">=1.3.8"
	}
}
